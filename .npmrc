# Skip package install scripts.
#
# blue-js-sdk's postinstall (bin/setup.js) runs a nested `npm install`,
# downloads a ~20 MB V2Ray zip from GitHub releases, and on macOS runs
# `brew install wireguard-tools`. The Plan Manager doesn't use V2Ray or
# WireGuard — we only call blue-js-sdk's chain helpers — so skipping
# postinstalls drops `npm install` time from minutes to seconds.
#
# The only other install-time script in the tree (protobufjs) is a
# harmless version-scheme warning. Safe to skip.
ignore-scripts=true
